# ---------------------------------------------------------------------------
# .env.sample — Template for local development environment variables
# ---------------------------------------------------------------------------
# Copy this to .env and fill in values for local development.
# These are set automatically by azd when deploying to Azure.
# ---------------------------------------------------------------------------

# Microsoft Foundry (leave empty for local-only mode)
# Endpoint format: https://<resource>.services.ai.azure.com/api/projects/<project>
PROJECT_ENDPOINT=
MODEL_DEPLOYMENT=gpt-4o

# Authentication — choose ONE approach:
#   Option 1: API key (quickest for local dev)
PROJECT_API_KEY=
#   Option 2: Managed Identity (deployed environments — leave key empty)
AZURE_CLIENT_ID=

# Bing Grounding (optional — enables live web search in Research Agent)
# Resource ID format: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>/connections/bing-grounding
BING_CONNECTION_ID=

# Observability (optional for local dev)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=DEBUG

# Orchestration
MAX_AGENT_TURNS=10
